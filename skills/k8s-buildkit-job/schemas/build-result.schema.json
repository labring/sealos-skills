{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skills.sh/k8s-buildkit-job/schemas/build-result.schema.json",
  "title": "K8s BuildKit Job Build Result Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated_at",
    "status",
    "mode",
    "image",
    "source",
    "logs"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "skipped"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "reuse-image",
        "build-required"
      ]
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image_ref",
        "digest"
      ],
      "properties": {
        "image_ref": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^sha256:[a-fA-F0-9]{64}$"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "github_url",
        "repo",
        "ref",
        "context_path",
        "dockerfile_path"
      ],
      "properties": {
        "github_url": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "repo": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "context_path": {
          "type": "string",
          "minLength": 1
        },
        "dockerfile_path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "kubernetes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "namespace",
        "job",
        "pod"
      ],
      "properties": {
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "job": {
          "type": "string",
          "minLength": 1
        },
        "pod": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "logs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_file"
      ],
      "properties": {
        "local_file": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "message"
      ],
      "properties": {
        "phase": {
          "type": "string",
          "enum": [
            "preflight",
            "build-request",
            "auth",
            "clone",
            "dockerfile",
            "buildkit",
            "push",
            "kubernetes",
            "timeout",
            "unknown"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "failed"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "error"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "succeeded",
              "failed"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "kubernetes"
        ]
      }
    }
  ]
}
