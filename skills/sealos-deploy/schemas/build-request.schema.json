{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skills.sh/sealos-deploy/schemas/build-request.schema.json",
  "title": "Sealos Deploy Build Request Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated_at",
    "source",
    "mode",
    "image",
    "build",
    "runtime"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "github_url",
        "repo",
        "ref",
        "work_dir"
      ],
      "properties": {
        "github_url": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "repo": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "work_dir": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "mode": {
      "type": "string",
      "enum": [
        "reuse-image",
        "build-required"
      ]
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image_ref",
        "target_image"
      ],
      "properties": {
        "image_ref": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "target_image": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_path",
        "dockerfile_path",
        "build_args"
      ],
      "properties": {
        "context_path": {
          "type": "string",
          "minLength": 1
        },
        "dockerfile_path": {
          "type": "string",
          "minLength": 1
        },
        "build_args": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "port"
      ],
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    }
  }
}
