{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skills.sh/sealos-deploy/schemas/template-references.schema.json",
  "title": "Sealos Deploy Template References Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generated_at",
    "catalog",
    "project",
    "references",
    "summary",
    "decision",
    "reference_dir",
    "reason"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "2.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "available",
        "repository",
        "ref",
        "commit",
        "source",
        "stale",
        "verified_for_reuse",
        "template_count",
        "skipped_templates",
        "reason"
      ],
      "properties": {
        "available": {
          "type": "boolean"
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^[0-9a-f]{7,64}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "source": {
          "type": "string",
          "enum": [
            "refreshed",
            "cache",
            "local",
            "unavailable"
          ]
        },
        "stale": {
          "type": "boolean"
        },
        "verified_for_reuse": {
          "type": "boolean"
        },
        "template_count": {
          "type": "integer",
          "minimum": 0
        },
        "skipped_templates": {
          "type": "integer",
          "minimum": 0
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "github_url",
        "repo_reference",
        "repo_subdir",
        "features"
      ],
      "properties": {
        "github_url": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "repo_reference": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^[^/\\s]+/[^/\\s]+$"
            },
            {
              "type": "null"
            }
          ]
        },
        "repo_subdir": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "features": {
          "$ref": "#/$defs/projectFeatures"
        }
      }
    },
    "references": {
      "type": "array",
      "maxItems": 15,
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exact_count",
        "similar_count"
      ],
      "properties": {
        "exact_count": {
          "type": "integer",
          "minimum": 0
        },
        "similar_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "reuse_requested",
        "reference_name",
        "template_path",
        "reason"
      ],
      "properties": {
        "route": {
          "type": "string",
          "enum": [
            "deploy_official_template",
            "continue_standard_pipeline"
          ]
        },
        "reuse_requested": {
          "type": "boolean"
        },
        "reference_name": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "template_path": {
          "anyOf": [
            {
              "type": "string",
              "const": ".sealos/template/index.yaml"
            },
            {
              "type": "null"
            }
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "reference_dir": {
      "type": "string",
      "const": ".sealos/template-references"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "database": {
      "type": "string",
      "enum": [
        "postgres",
        "mysql",
        "mongodb",
        "redis",
        "kafka",
        "sqlite"
      ]
    },
    "projectFeatures": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "app_workloads",
        "databases",
        "framework",
        "language",
        "object_storage",
        "persistent",
        "roles",
        "websocket"
      ],
      "properties": {
        "app_workloads": {
          "type": "integer",
          "minimum": 1
        },
        "databases": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/database"
          }
        },
        "framework": {
          "type": "string"
        },
        "language": {
          "type": "string",
          "minLength": 1
        },
        "object_storage": {
          "type": "boolean"
        },
        "persistent": {
          "type": "boolean"
        },
        "roles": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "websocket": {
          "type": "boolean"
        }
      }
    },
    "referenceFeatures": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "categories",
        "databases",
        "kinds",
        "images",
        "object_storage",
        "persistent",
        "roles",
        "websocket"
      ],
      "properties": {
        "categories": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "databases": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/database"
          }
        },
        "kinds": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 1
          }
        },
        "images": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "object_storage": {
          "type": "boolean"
        },
        "persistent": {
          "type": "boolean"
        },
        "roles": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "websocket": {
          "type": "boolean"
        }
      }
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "title",
        "git_repo",
        "match",
        "score",
        "reasons",
        "warnings",
        "catalog_path",
        "reference_path",
        "source_url",
        "features"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "git_repo": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "match": {
          "type": "string",
          "enum": [
            "exact",
            "similar"
          ]
        },
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "warnings": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "catalog_path": {
          "type": "string",
          "pattern": "^[^/]+/index\\.yaml$"
        },
        "reference_path": {
          "type": "string",
          "pattern": "^\\.sealos/template-references/[^/]+\\.yaml$"
        },
        "source_url": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^https://raw\\.githubusercontent\\.com/"
            },
            {
              "type": "null"
            }
          ]
        },
        "features": {
          "$ref": "#/$defs/referenceFeatures"
        }
      }
    }
  }
}
