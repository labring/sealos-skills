flowchart TD
    A["User runs /sealos-deploy<br/>GitHub URL, local path, or current project"]
    P0["Phase 0 - Preflight<br/>Capabilities, Sealos auth, workspace, and project context"]
    M{"Existing live deployment?"}

    U1["Phase U1 - Choose rebuild or restart"]
    U2["Phase U2 - Apply in-place update"]
    U3["Phase U3 - Verify rollout and runtime<br/>Rollback on failure"]

    P1{"Phase 1 - Is deployment certainly impossible?"}
    Stop1["Stop with one concrete reason"]
    Assess["Score readiness and record project requirements<br/>Low score warns but does not reject"]
    P15{"Phase 1.5 - Unique verified official template?"}
    Official["Reuse official template verbatim"]

    P2["Phase 2 - Discover images and full topology<br/>README, then CI, then Compose; implicit app for no-Compose source"]
    Digest{"Every emitted container workload has<br/>an immutable digest?"}
    Reuse["Reuse digest-pinned images<br/>No third-party architecture pre-screen"]
    P3["Phase 3 - Prepare each missing container service<br/>Preserve existing Dockerfile; exact context, path, target, and arg names"]
    P4["Phase 4 - Build and push each planned service<br/>Target linux/amd64; digest from Buildx metadata"]
    Repair{"Concrete build failure?"}
    P5["Phase 5 - Generate complete Sealos template"]
    P55["Phase 5.5 - Validate, configure, and confirm"]
    P6["Phase 6 - Resolve inputs, dry-run, and deploy"]
    P65{"Phase 6.5 - Runtime truth pass"}
    Recover{"Confirmed image architecture mismatch<br/>and buildable source?"}
    Stop2["Report the exact blocking service, image, or runtime cause"]
    Done["Deployment accepted"]

    A --> P0 --> M
    M -- "Yes" --> U1 --> U2 --> U3 --> Done
    M -- "No" --> P1
    P1 -- "Yes" --> Stop1
    P1 -- "No or uncertain" --> Assess --> P15
    P15 -- "Yes" --> Official --> P6
    P15 -- "No" --> P2 --> Digest
    Digest -- "Yes" --> Reuse --> P5
    Digest -- "No - build only missing services" --> P3 --> P4 --> Repair
    Repair -- "No" --> P5
    Repair -- "Yes - return only failing service" --> P3
    P5 --> P55 --> P6 --> P65
    P65 -- "Pass" --> Done
    P65 -- "Architecture mismatch" --> Recover
    Recover -- "Yes" --> P3
    Recover -- "No" --> Stop2
    P65 -- "Other runtime failure" --> Stop2
